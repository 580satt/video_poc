# Required for Gemini
GEMINI_API_KEY=

# Set true to persist runs in MongoDB; false = in-memory only (no DB writes — `MONGODB_COLLECTION` never appears).
USE_MONGODB=false

# MongoDB — if the server enforces auth, include username/password and authSource:
#   MONGODB_URI=mongodb://USER:PASSWORD@localhost:27017/?authSource=admin
# Atlas: paste the SRV connection string from the cluster “Connect” dialog (it includes the user).
# If you see: "Command createIndexes requires authentication" your URI is missing valid credentials.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ads_scraper_db
# One collection for run state and appended output events (e.g. final payload on complete).
MONGODB_COLLECTION=video_ad_pipeline

# Models (adjust to your API tier)
# Story + scenes JSON when STORY_SCENES_LLM_PROVIDER=gemini (image gen always uses GEMINI_IMAGE_MODEL)
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_REVIEWER_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Optional: Claude for story + scenes only (OpenAI-compatible WaveSpeed API)
# STORY_SCENES_LLM_PROVIDER=gemini
# WAVESPEED_API_KEY=
# WAVESPEED_BASE_URL=https://llm.wavespeed.ai/v1
# WAVESPEED_MODEL=anthropic/claude-opus-4.7
# WAVESPEED_MAX_OUTPUT_TOKENS=16384
# GEMINI_MAX_OUTPUT_TOKENS=8192
# Image frames: true = photoreal / TV-commercial photo look (default). false = illustrated storybook art.
# IMAGE_PHOTOREALISTIC=true

# Revision caps (max review loops per stage)
MAX_SCRIPT_REVISIONS=10
MAX_SCENES_REVISIONS=10
MAX_IMAGE_REVISIONS=10

# Default pacing (8–10s ad spot)
TARGET_RUNTIME_SECONDS=8
TARGET_RUNTIME_MAX_SECONDS=10

# Artifacts on disk
ARTIFACTS_DIR=artifacts

# AWS S3 (scene frame PNGs; credentials can come from the environment / instance role if keys are empty)
S3_BUCKET=
S3_KEY_PREFIX=storybook
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Optional: public or CDN base, no trailing slash (if unset, presigned or virtual-hosted URL is used)
# S3_PUBLIC_BASE_URL=
# S3_USE_PRESIGNED_URLS=true
# S3_PRESIGN_EXPIRES_SECONDS=604800
# S3_REFRESH_URL_ON_GET=true
# S3_ENDPOINT_URL=

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Optional: Chroma RAG + review memory (1536-dim vectors; e.g. VIDEO_DNA / VIDEO_DNA_FULL)
# CHROMA_PERSIST_PATH=/path/to/chroma-db
# CHROMA_NARRATIVE_COLLECTION=VIDEO_DNA
# CHROMA_REVIEW_COLLECTION=REVIEWER_FEEDBACK
# RAG_ENABLED=true
# RAG_TOP_K=5
# Azure OpenAI (ada-002) — used when all three are set; same as many existing Chroma indexes
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2023-05-15
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
# Or direct OpenAI if Azure is not used:
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536
# REVIEWER_MIN_RATING=4
# REVIEW_MEMORY_TOP_K=3
